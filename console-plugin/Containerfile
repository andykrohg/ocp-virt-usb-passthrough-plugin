# Build stage
FROM registry.access.redhat.com/ubi9/nodejs-18:latest AS builder

USER root

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Build the plugin
RUN npm run build

# Runtime stage
FROM registry.access.redhat.com/ubi9/nginx-120:latest

USER root

# Copy built plugin files
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration (replace main config)
COPY nginx.conf /etc/nginx/nginx.conf

# Fix permissions for OpenShift random UID
RUN chmod -R 755 /usr/share/nginx/html && \
    chown -R 1001:0 /usr/share/nginx/html && \
    chmod 644 /etc/nginx/nginx.conf && \
    chmod -R g+rwX /var/log/nginx /var/lib/nginx /tmp

# Labels
LABEL name="usb-passthrough-console-plugin" \
      vendor="OpenShift" \
      version="0.1.0" \
      summary="USB Passthrough Console Plugin for OpenShift" \
      description="Dynamic console plugin for managing USB device passthrough to VMs"

USER 1001

EXPOSE 9443

CMD ["nginx", "-g", "daemon off;"]
